rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentRole() {
      return userDocExists() ? currentUserData().role : '';
    }

    function isAdmin() {
      return currentRole() == 'admin';
    }

    function isSchool() {
      return currentRole() == 'school';
    }

    function isTeacher() {
      return currentRole() == 'teacher';
    }

    function isStudent() {
      return currentRole() == 'student';
    }

    function isOwnUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentSchoolId() {
      return !userDocExists()
        ? ''
        : (
            currentRole() == 'school'
              ? request.auth.uid
              : (
                  currentUserData().schoolId is string
                    ? currentUserData().schoolId
                    : ''
                )
          );
    }

    function sameSchool(schoolId) {
      return signedIn() && currentSchoolId() == schoolId;
    }

    function relatedStudentForTeacher(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.role == 'student'
        && get(/databases/$(database)/documents/users/$(userId)).data.teacherId == request.auth.uid;
    }

    function relatedLegacyStudentInSameSchool(studentId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(studentId))
        && get(/databases/$(database)/documents/users/$(studentId)).data.teacherId == request.auth.uid;
    }

    function relatedStudentForSchool(userId) {
      return isSchool()
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.role == 'student'
        && get(/databases/$(database)/documents/users/$(userId)).data.schoolId == request.auth.uid;
    }

    function validRole(role) {
      return role == 'admin' || role == 'school' || role == 'teacher' || role == 'student';
    }

    function validSchoolPayload(data, userId) {
      return data.id == userId
        && data.name is string
        && data.name.size() > 0
        && data.email is string
        && data.email.size() > 3
        && data.role == 'school';
    }

    function validUserPayload(data, userId) {
      return data.id == userId
        && data.name is string
        && data.name.size() > 0
        && data.email is string
        && data.email.size() > 3
        && validRole(data.role)
        && data.schoolId is string
        && data.schoolId.size() > 0
        && (
          data.role != 'student'
          || (
            data.teacherId is string
            && data.teacherId.size() > 0
          )
        );
    }

    function validProgressPayload(data) {
      return data.userId is string
        && data.userId.size() > 0
        && data.lessonId is string
        && data.lessonId.size() > 0
        && data.completed is bool
        && data.score is number
        && data.score >= 0
        && data.score <= 100
        && data.xpEarned is number
        && data.xpEarned >= 0
        && data.date is timestamp;
    }

    function validEmotionType(type) {
      return type == 'happy'
        || type == 'focused'
        || type == 'curious'
        || type == 'tired'
        || type == 'frustrated';
    }

    function validEmotionPayload(data) {
      return data.studentId is string
        && data.studentId.size() > 0
        && data.type is string
        && validEmotionType(data.type)
        && data.confidence is number
        && data.confidence >= 0
        && data.confidence <= 1;
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || (isSchool()
          && resource.data.schoolId is string
          && resource.data.schoolId == request.auth.uid)
        || (isTeacher()
          && resource.data.role == 'school'
          && userId == currentSchoolId())
        || (isTeacher()
          && resource.data.role == 'student'
          && resource.data.teacherId is string
          && resource.data.teacherId == request.auth.uid)
        || isOwnUser(userId);

      allow create: if (isAdmin()
          && validUserPayload(request.resource.data, userId)
          && request.resource.data.role == 'teacher')
        || (
          isSchool()
          && validUserPayload(request.resource.data, userId)
          && request.resource.data.role == 'teacher'
          && request.resource.data.schoolId == request.auth.uid
        )
        || (
          isAdmin()
          && validSchoolPayload(request.resource.data, userId)
        )
        || (
          isTeacher()
          && validUserPayload(request.resource.data, userId)
          && request.resource.data.role == 'student'
          && request.resource.data.teacherId == request.auth.uid
          && sameSchool(request.resource.data.schoolId)
        );

      allow update: if (isAdmin() && (
            validUserPayload(request.resource.data, userId)
            || validSchoolPayload(request.resource.data, userId)
          ))
        || (
          isTeacher()
          && validUserPayload(request.resource.data, userId)
          && resource.data.role == 'student'
          && resource.data.teacherId == request.auth.uid
          && request.resource.data.teacherId == request.auth.uid
          && request.resource.data.schoolId == resource.data.schoolId
        );

      allow delete: if isAdmin()
        || (
          isSchool()
          && resource.data.schoolId is string
          && resource.data.schoolId == request.auth.uid
          && (resource.data.role == 'teacher' || resource.data.role == 'student')
        )
        || (
          isTeacher()
          && resource.data.role == 'student'
          && resource.data.teacherId is string
          && resource.data.teacherId == request.auth.uid
        );
    }

    match /schools/{schoolId} {
      allow read, write: if isAdmin();
    }

    match /chapters/{chapterId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /exercises/{exerciseId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /progress/{progressId} {
      allow read: if isAdmin()
        || (isSchool() && resource.data.userId is string && relatedStudentForSchool(resource.data.userId))
        || (isSchool() && resource.data.studentId is string && relatedStudentForSchool(resource.data.studentId))
        || (isTeacher() && resource.data.userId is string && relatedStudentForTeacher(resource.data.userId))
        || (isTeacher() && resource.data.studentId is string && relatedLegacyStudentInSameSchool(resource.data.studentId))
        || (isStudent() && resource.data.userId is string && resource.data.userId == request.auth.uid)
        || (isStudent() && resource.data.studentId is string && resource.data.studentId == request.auth.uid);

      allow create: if (isAdmin() && validProgressPayload(request.resource.data))
        || (
          isStudent()
          && validProgressPayload(request.resource.data)
          && request.resource.data.userId == request.auth.uid
        );

      allow update: if (isAdmin() && validProgressPayload(request.resource.data))
        || (
          isStudent()
          && validProgressPayload(request.resource.data)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
        );

      allow delete: if isAdmin()
        || (isSchool() && resource.data.userId is string && relatedStudentForSchool(resource.data.userId))
        || (isSchool() && resource.data.studentId is string && relatedStudentForSchool(resource.data.studentId))
        || (isTeacher() && resource.data.userId is string && relatedStudentForTeacher(resource.data.userId))
        || (isTeacher() && resource.data.studentId is string && relatedLegacyStudentInSameSchool(resource.data.studentId));
    }

    match /emotions/{emotionId} {
      allow read: if isAdmin()
        || (isSchool() && resource.data.studentId is string && relatedStudentForSchool(resource.data.studentId))
        || (isTeacher() && resource.data.studentId is string && relatedStudentForTeacher(resource.data.studentId))
        || (isStudent() && resource.data.studentId is string && resource.data.studentId == request.auth.uid);

      allow create: if (isAdmin() && validEmotionPayload(request.resource.data))
        || (
          isStudent()
          && validEmotionPayload(request.resource.data)
          && request.resource.data.studentId == request.auth.uid
        );

      allow update, delete: if isAdmin()
        || (isSchool() && resource.data.studentId is string && relatedStudentForSchool(resource.data.studentId))
        || (isTeacher() && resource.data.studentId is string && relatedStudentForTeacher(resource.data.studentId));
    }
  }
}
